name = "steam-review-summary-mcp"
main = "src/worker.ts"
compatibility_date = "2025-03-01"

# Enable workers dev URL
workers_dev = true

# Optional custom domain (uncomment if you configure a route)
# routes = [
#   { pattern = "api.yourdomain.com/mcp", zone_name = "yourdomain.com" }
# ]

# KV namespaces for caching and rate limiting
[[kv_namespaces]]
binding = "SUMMARY_CACHE"
id = "REPLACE_WITH_ID"

[[kv_namespaces]]
binding = "RATE_LIMIT"
id = "REPLACE_WITH_ID"

# Recommended limits / settings
[vars]
SERVICE_NAME = "steam-review-summary-mcp"

# Optional observability
[observability.logs]
enabled = true
